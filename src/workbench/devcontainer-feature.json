{
    "name": "Workbench",
    "id": "workbench",
    "version": "1.1.1",
    "description": "Installs coding agents, Git tools, terminal utilities, Python, linters, Neovim, and Zsh.",
    "customizations": {
        "vscode": {
            "extensions": [
                "OpenAI.chatgpt"
            ]
        }
    },
    "dependsOn": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": false,
            "configureZshAsDefaultShell": false,
            "installOhMyZsh": false,
            "installOhMyZshConfig": false,
            "upgradePackages": false
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        }
    }
}
