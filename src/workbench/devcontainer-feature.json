{
    "name": "Workbench",
    "id": "workbench",
    "version": "1.1.0",
    "description": "Installs coding agents, Git tools, terminal utilities, Python, linters, Neovim, and Zsh.",
    "customizations": {
        "vscode": {
            "extensions": [
                "asvetliakov.vscode-neovim",
                "OpenAI.chatgpt"
            ],
            "settings": {
                "remote.extensionKind": {
                    "asvetliakov.vscode-neovim": [
                        "workspace"
                    ]
                }
            }
        }
    },
    "dependsOn": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": false,
            "configureZshAsDefaultShell": false,
            "installOhMyZsh": false,
            "installOhMyZshConfig": false,
            "upgradePackages": false
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        }
    }
}
